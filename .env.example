# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_teacher

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_REFRESH_EXPIRES_IN=7d

# AI (DeepSeek)
AI_API_KEY=sk-your-deepseek-api-key
AI_MODEL=deepseek-chat
AI_BASE_URL=https://api.deepseek.com/v1

# Encryption (for API keys)
ENCRYPTION_KEY=change-me-to-a-random-32-char-string

# Storage
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage
# Storage subdirectories: original/ preview/ export/ thumbnail/ temp/ trash/

# Preview Engine
PREVIEW_ENGINE=libreoffice

# Upload
UPLOAD_MAX_SIZE_MB=200

# API
API_PORT=3000
WEB_PORT=8080
