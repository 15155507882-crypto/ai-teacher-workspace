# ============================================================
# AI 教师工作空间 - 生产环境变量模板
# 复制此文件为 .env 并填入真实值
# cp .env.production.example .env
# ============================================================

# ---------- 数据库 ----------
POSTGRES_USER=postgres
# ⚠️ 必须修改：数据库密码
POSTGRES_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
POSTGRES_DB=ai_teacher

# ---------- JWT 密钥 ----------
# ⚠️ 必须修改：使用 openssl rand -base64 32 生成
JWT_SECRET=CHANGE_ME_JWT_SECRET_32_CHARS_MIN
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_32_CHARS_MIN
JWT_REFRESH_EXPIRES_IN=7d

# ---------- 加密密钥 ----------
# ⚠️ 必须修改：AES-256 需要 32 字符密钥
ENCRYPTION_KEY=CHANGE_ME_TO_RANDOM_32_CHAR_STRING

# ---------- CORS ----------
# ⚠️ 必须修改：生产前端域名
WEB_URL=https://your-domain.com

# ---------- 存储 ----------
STORAGE_BACKEND=local
UPLOAD_MAX_SIZE_MB=200

# ---------- AI (DeepSeek) ----------
# ⚠️ 必须修改：DeepSeek API Key
AI_API_KEY=sk-your-deepseek-api-key
AI_MODEL=deepseek-chat
AI_BASE_URL=https://api.deepseek.com/v1

# ---------- Docker 镜像 ----------
DOCKER_REGISTRY=docker.io
DOCKER_NAMESPACE=geliangbin7882
IMAGE_TAG=latest
